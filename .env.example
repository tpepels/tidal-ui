# squid.wtf special
TITLE=
SLOGAN=
PORT=

# Redis connection parameters
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false

# Optional Redis cache tuning (defaults shown)
REDIS_CACHE_TTL_SECONDS=300
REDIS_CACHE_TTL_SEARCH_SECONDS=300
REDIS_CACHE_TTL_TRACK_SECONDS=120
REDIS_CACHE_TTL_IMAGE_SECONDS=604800
REDIS_CACHE_MAX_BODY_BYTES=200000
REDIS_CACHE_MAX_IMAGE_BODY_BYTES=1500000

# Optional proxy hardening for local/single-user setups
# Keep default false to enforce same-origin access when Origin is present.
PROXY_ALLOW_ANY_ORIGIN=false
# Keep default true to block localhost/LAN/private-IP proxy targets.
PROXY_BLOCK_PRIVATE_TARGETS=true
# Optional comma-separated hostname allowlist (empty = allow all public hosts).
PROXY_ALLOWED_TARGET_HOSTS=

# Optional TIDAL official-discography cache tuning (defaults shown)
TIDAL_OFFICIAL_DISCOGRAPHY_CACHE_TTL_SECONDS=172800
TIDAL_OFFICIAL_DISCOGRAPHY_EMPTY_TTL_SECONDS=172800
TIDAL_OFFICIAL_DISCOGRAPHY_MEMORY_MAX_ENTRIES=500
TIDAL_PAGE_FETCH_BETWEEN_PAGES_MS=200

# Queue/download concurrency tuning (lower values reduce upstream 429 rate limits)
WORKER_MAX_CONCURRENT=4
ALBUM_TRACK_CONCURRENCY=2
ALBUM_TRACK_MAX_ATTEMPTS=12
ALBUM_RETRY_BASE_DELAY_MS=5000
ALBUM_RETRY_MAX_DELAY_MS=300000

# Media-library maintenance locking and safety sweep tuning
MEDIA_LIBRARY_MAINTENANCE_LOCK_TTL_MS=120000
MEDIA_LIBRARY_MAINTENANCE_LOCK_HEARTBEAT_MS=10000
MEDIA_LIBRARY_PUBLISH_LOCK_WAIT_MS=120000
MEDIA_LIBRARY_TRANSIENT_SWEEP_MIN_AGE_MS=1800000
# Optional override for maintenance run report directory
# MEDIA_MAINTENANCE_REPORTS_DIR=/tmp/tidal-ui-maintenance-runs

# Dynamic uptime target trust policy (comma-separated host allowlist)
# API_TARGET_ALLOWED_HOSTS= (no longer used — dynamic targets are accepted if they pass HTTPS + DNS private-IP checks)

# Final audio integrity gate (ffprobe, always enforced)
# Optional explicit ffprobe path (auto-discovery used when empty)
FFPROBE_PATH=
# Optional absolute duration tolerance override (seconds)
# FFPROBE_DURATION_TOLERANCE_SECONDS=8

# Optional Shaka CDN override (leave blank to use default)
VITE_SHAKA_CDN_URL=
